{
  "name": "thirsttrap.gay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm:dev:next\" \"pnpm:dev:db\" --names \"next,supabase\" --prefix-colors \"cyan,green\"",
    "dev:next": "next dev --webpack",
    "dev:db": "supabase start",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.83.0",
    "@payloadcms/next": "3.83.0",
    "@payloadcms/richtext-lexical": "3.83.0",
    "@payloadcms/storage-s3": "3.83.0",
    "@payloadcms/ui": "3.83.0",
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "graphql": "^16.13.2",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next": "^16.2.4",
    "payload": "3.83.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "resend": "^6.12.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.3.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "supabase",
      "unrs-resolver"
