# Database Configuration (Neon Postgres)
# Use the pooled connection string from your Neon dashboard
DATABASE_URI=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_PROJECT-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# Payload CMS Secret (generate with: openssl rand -base64 32)
PAYLOAD_SECRET=your-secret-key-here

# Cache Revalidation Secret (generate with: openssl rand -base64 32)
REVALIDATE_SECRET=your-revalidation-secret-here

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
